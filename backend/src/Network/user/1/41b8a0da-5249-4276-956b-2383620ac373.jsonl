eta.main) {\n  const numbers = [64, 34, 25, 12, 22, 11, 90];\n  console.log(\"Original:\", numbers);\n  console.log(\"Sorted:\", quickSort([...numbers]));\n\n  const strings = [\"banana\", \"apple\", \"cherry\", \"date\"];\n  console.log(\"Strings:\", quickSort(strings));\n}\n\nexport { quickSort, quickSortInPlace };\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"5a6b7cb5-3d65-4c2b-814b-e14692408b5d","userType":"external","entrypoint":"cli","cwd":"C:\\Users\\kuro\\Desktop\\code\\claude-code-rev\\backend","sessionId":"41b8a0da-5249-4276-956b-2383620ac373","version":"999.0.0-restored","gitBranch":"User-Separate"}
